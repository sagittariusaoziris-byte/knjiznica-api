# .env — Knjižnica lokalni razvoj
# Kopirajte ovu datoteku kao ".env" u folder fixed_api/
# NE commitati u git!

# HMAC secret za licencni sustav (potreban za pokretanje od v8.5.6)
# Ovo je LOKALNA razvojna vrijednost — za produkciju generiraj novu!
KNJIZNICA_HMAC_SECRET=dev_lokalni_secret_promijeniti_za_produkciju_32ch

# JWT secret za autentikaciju
KNJIZNICA_SECRET_KEY=dev_jwt_secret_lokalni_promijeniti_za_produkciju_32

# Baza podataka — SQLite lokalno (fallback ako DATABASE_URL nije postavljen)
# Za Supabase: DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_URL=sqlite:///./library.db
